# GravitonKV environment template. Copy to .env and fill in.
# No real credentials belong in this repository, ever.

# AWS (harness provisioning and S3 result streaming)
AWS_REGION=us-east-1
S3_RESULTS_BUCKET=your-results-bucket

# Hugging Face (optional; all six models are public, token only raises rate limits)
HF_TOKEN=hf_your_token_here
